{
  "dashboard": {
    "title": "Aether AI - System Overview",
    "tags": ["aether", "overview"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "API Request Rate",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum(rate(api_requests_total[5m]))",
            "legendFormat": "Total Requests/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "API Latency (p50, p95, p99)",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(api_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(api_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(api_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "Memory Usage",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job='aether-api'} / (1024*1024*1024)",
            "legendFormat": "Memory (GB)"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "AI Model Usage",
        "type": "piechart",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum by(provider) (increase(ai_requests_total[1h]))",
            "legendFormat": "{{provider}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 5,
        "title": "Error Rate",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "sum(rate(api_requests_total{status=~'5..'}[5m]))",
            "legendFormat": "5xx Errors/sec"
          },
          {
            "expr": "sum(rate(api_requests_total{status=~'4..'}[5m]))",
            "legendFormat": "4xx Errors/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 6,
        "title": "AI Cost (Last 24h)",
        "type": "singlestat",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "increase(ai_cost_total_usd[24h])",
            "legendFormat": "Cost ($)"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
        "format": "currencyUSD"
      },
      {
        "id": 7,
        "title": "Active Users",
        "type": "singlestat",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "count(count by(user_id) (increase(api_requests_total[5m]) > 0))",
            "legendFormat": "Users"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16}
      }
    ],
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
